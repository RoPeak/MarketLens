# Copy this file to .env and fill in values as needed.
# All settings have sensible defaults — only override what you need.

# Path to the DuckDB database file (relative to project root)
DB_PATH=data/marketlens.duckdb

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Prefect API URL (leave empty to run without Prefect server UI)
PREFECT_API_URL=

# CoinGecko API base URL (public API, no key required)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Comma-separated list of Yahoo Finance tickers to track
YFINANCE_TICKERS=["SPY","QQQ","GLD","TLT","IWM"]

# Comma-separated CoinGecko coin IDs
CRYPTO_IDS=["bitcoin","ethereum","solana"]

# FRED series IDs for macro data
MACRO_SERIES=["DGS10","FEDFUNDS","UNRATE"]

# How many days of history to ingest on first run
LOOKBACK_DAYS=730
